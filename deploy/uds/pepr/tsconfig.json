{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "module": "es2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "rootDir": ".",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "useUnknownInCatchVariables": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
