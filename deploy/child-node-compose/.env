# THESEUS child-node (edge) model server — environment.
# Copy/edit to match your network, then:
#   docker compose -f deploy/child-node-compose/model-serv.yml --env-file deploy/child-node-compose/.env up --build

# Central MLflow tracking server (deploy/mlflow-compose/). LAN IP of the host
# running it. OPTIONAL for serving — the edge serves offline from the promoted
# model; this is used by the shore-side retrain step (demo/retrain.py).
MLFLOW_SERVER_HOST=192.168.1.100
MLFLOW_SERVER_PORT=5050

# MLflow experiment name the shore retrain logs into.
MLFLOW_EXPERIMENT_NAME=theseus-cbm
