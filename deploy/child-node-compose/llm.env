# THESEUS child-node (edge) LLM server — environment.
# Copy/edit to match your node, then:
#   podman compose -f deploy/child-node-compose/llm-serv.yml --env-file deploy/child-node-compose/llm.env up -d

# Where the GGUF weights live ON THE HOST (gitignored; never committed).
# Repo-relative default works from the repo root; on a Pi point it at the
# real model dir, e.g. /home/pi1/models.
MODELS_DIR=../../models

# Which model to serve. Qwen2.5-3B drives Goose tool-calls reliably (~4 tok/s);
# qwen2.5-1.5b-instruct-q4_k_m.gguf is a faster chat-only fallback.
LLM_MODEL_FILE=qwen2.5-3b-instruct-q4_k_m.gguf

# Context window. 8192 fits Goose's system prompt + tool schemas with headroom;
# keep GOOSE_CONTEXT_LIMIT just under this so the agent compacts before the cap.
LLM_CTX=8192

# Threads = physical cores (Pi 5 = 4).
LLM_THREADS=4

# Host port. Defaults to 8080 (same as model-serv.yml) — change to 8081 to run
# the CBM model-server and this LLM server on the same node at once.
LLM_PORT=8080

# Resource caps for a 4GB Pi.
LLM_MEM_LIMIT=3g
LLM_CPUS=4.0
